{
    "name": "jo-81/portfolio-headless",
    "description": "Plugin WordPress headless - API REST pour portfolio Astro.js",
    "type": "wordpress-plugin",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "PortfolioHeadless\\": "src/"
        }
    },
    "authors": [
        {
            "name": "jo-81",
            "email": "geoffroy.colpart81@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.7",
        "wp-coding-standards/wpcs": "^3.0",
        "symfony/var-dumper": "^7.1",
        "phpstan/phpstan": "^2.1",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-phpunit": "^2.0",
        "php-stubs/wordpress-tests-stubs": "^6.9"
    },
    "scripts": {
        "lint":     "phpcs src/",
        "lint:fix": "phpcbf src/",
        "phpstan": "phpstan analyse --memory-limit=1G --ansi"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true
        }
    }
}
